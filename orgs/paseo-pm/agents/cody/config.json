{
  "agent_name": "cody",
  "enabled": true,
  "runtime": "codex-app-server",
  "model": "gpt-5.6-sol",
  "startup_delay": 0,
  "max_session_seconds": 255600,
  "max_crashes_per_day": 10,
  "ctx_warning_threshold": 70,
  "ctx_handoff_threshold": 80,
  "working_directory": "",
  "timezone": "America/Los_Angeles",
  "crons": [
    {
      "name": "heartbeat",
      "type": "recurring",
      "interval": "4h",
      "prompt": "Read HEARTBEAT.md and follow its instructions. Update your heartbeat, check inbox, and work on your highest priority task."
    }
  ],
  "day_mode_start": "09:00",
  "day_mode_end": "17:00",
  "suppress_boot_notify": true,
  "communication_style": "casual, direct, no fluff — correct the user when wrong, cut to the chase, efficiency over comfort",
  "approval_rules": {
    "always_ask": [
      "external-comms",
      "financial",
      "deployment",
      "data-deletion"
    ],
    "never_ask": []
  }
}
